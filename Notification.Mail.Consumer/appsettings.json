{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information",
      "MassTransit": "Information"
    }
  },
  "Serilog": {
    "Elasticsearch": {
      "Uri": "http://localhost:9200",
      "IndexFormat": "notification-mail-consumer-logs",
      "AutoRegisterTemplate": true
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=NotificationDB;Username=postgres;Password=enes543321"
  },
  "RabbitMQ": {
    "Url": "amqp://guest:guest@localhost:5672/",
    "QueuePrefix": "NotificationMail"
  },
  "MessageRetry": {
    "MaxRetryCount": 5,
    "MinIntervalSeconds": 1,
    "MaxIntervalMinutes": 5,
    "IntervalDeltaSeconds": 2
  },
  "MassTransit": {
    "Inbox": {
      "DuplicateDetectionWindowMinutes": 5,
      "QueryDelaySeconds": 60,
      "DisableCleanupService": false
    }
  },
  "Smtp": {
    "Host": "localhost",
    "Port": 25,
    "EnableSsl": false,
    "UserName": "",
    "Password": "",
    "FromAddress": "no-reply@ecommerce.local"
  }
}

